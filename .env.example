# Environment Configuration for E-commerce Demo

# ========================
# Backend Configuration
# ========================

# Database
DATABASE_URL=sqlite:///./store.db

# Currency Exchange API
# OpenExchangeRates API key (optional - uses mock rates if not provided)
# Get your free API key at: https://openexchangerates.org/signup/free
FX_API_KEY=your_openexchangerates_api_key_here

# Allowed currencies for conversion (comma-separated)
ALLOWED_CURRENCIES=USD,GBP,EUR,AUD,MXN,JPY

# FX service configuration
FX_CACHE_TTL_HOURS=1
FX_BASE_URL=https://openexchangerates.org/api

# Application settings
DEBUG=true
DISABLE_SCHEDULER=false

# ========================
# Frontend Configuration
# ========================

# API endpoint for frontend
VITE_API_URL=http://localhost:8001

# Default currency for frontend
VITE_DEFAULT_CURRENCY=USD

# ========================
# Development/Testing
# ========================

# Test environment settings (automatically set during tests)
# PYTEST_CURRENT_TEST=1
# DISABLE_SCHEDULER=true
